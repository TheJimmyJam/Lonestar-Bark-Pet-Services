# Copy this to .env.local and fill in your values.
# .env.local is gitignored — never commit real secrets.

# Shared secret for the notify-admin edge function.
# Generate one: node -e "console.log(require('crypto').randomUUID())"
# Set the SAME value in Supabase dashboard → Edge Functions → notify-admin → Secrets → NOTIFY_ADMIN_SECRET
VITE_NOTIFY_ADMIN_SECRET=your-secret-here
